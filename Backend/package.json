  "description": "Vehicle Fleet Parking Management — DDD/CQRS in TypeScript",
  "license": "proprietary",
  "author": "Badr Eddine ATTALBI ALAMI",
  "scripts": {
    "test": "cucumber-js --profile default",
    "test:critical": "cucumber-js --profile critical",
    "test:infra": "cucumber-js --profile infra",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "npm run lint && npm run format:check && npm test",
    "fleet": "ts-node src/Infra/cli.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.14",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.2"
  }
}
